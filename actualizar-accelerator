# --------------------------------------------------------------------
# Proceso principal
# --------------------------------------------------------------------

_msg start
_msg download
wget -q -O "$ZIP_NAME" "$DOWNLOAD_URL"

_msg unzip

rm -rf "$SRC_DIR"

if ! unzip -t "$ZIP_NAME" >/dev/null 2>&1; then
    _msg download_error
    exit 1
fi

unzip -q "$ZIP_NAME"

[ -d "$SRC_DIR" ] || { _msg no_dir; exit 1; }

# --------------------------------------------------------------------
# Parche content.php
# Neutraliza la condición que inyecta el banner publicitario en el
# footer. La función cambió de HtmlNd::Parse a HtmlNd::ParseAndImport
# en versiones recientes, por lo que se actúa sobre el if exterior.
# --------------------------------------------------------------------

_msg mod_content
CONTENT_FILE="$SRC_DIR/content.php"
awk '
/if\( \( \$ctxProcess\[ .mode. \] & 1 \) && \$seraph_accel_g_ahuddqrText \)/ {
    print "\tif( false ) /* Crealib: footer credits disabled */"
    next
}
{ print }
' "$CONTENT_FILE" > "$CONTENT_FILE.tmp" && mv "$CONTENT_FILE.tmp" "$CONTENT_FILE"

_msg mod_plugin
PLUGIN_FILE="$SRC_DIR/plugin_root.php"
awk '
BEGIN { h=1 }
/Plugin Name:/ { print "Plugin Name: Crealib Accelerator"; next }
/Plugin URI:/ { print "Plugin URI: https://www.crealib.net/plugin-accelerator"; next }
/Author: Seraphinite/ { print "Author: Crealib Tecnología Sostenible"; next }
/Author URI:/ { print "Author URI: https://www.crealib.net"; next }
/^\*\// { print; h=0; next }
{ print }
' "$PLUGIN_FILE" > "$PLUGIN_FILE.tmp" && mv "$PLUGIN_FILE.tmp" "$PLUGIN_FILE"

_msg rename
rm -rf "$DST_DIR"
mv "$SRC_DIR" "$DST_DIR"

_msg zip
rm -f "$OUT_ZIP"
zip -qr "$OUT_ZIP" "$DST_DIR"

_msg cleanup
rm -rf "$DST_DIR"
rm -rf Accelerator.zip

_msg done
