# Este script descarga la versión más reciente de Seraphinite Accelerator, 
# y haciendo uso de su licencia GPL modifica el código para quitar la
# publicidad en el footer de nuestra web. 
#
# Instrucciones: 
# 1) Ejecutar el script e instalar en WordpRess el plugin .zip
# resultante. 
# 2) Desactivar actualizaciones automáticas de plugins de WordPress
# 3) Cuando WordPress detecte una nueva actualización, volver a ejecutar este
# script, que descargará la versión más actual, para que la podamos subir
# parcheada en reemplazo de la anterior. 
#
# Cómo usar el plugin:
# Ir al panel de Accelerator y luego de actualizar alguna página de 
# nuestra web, presionar los siguientes botones en el siguiente orden:
#
# 1) Delete server's cache (if available)
# 2) Delete cache
# 3) Revalidate cache if needed
# 4) Revalidate cache. 
#
# No requiere configuración adicional. 
#
# Para verificar si hace buen efecto en nuestra web, recomiendo medir
# el rendimiento antes y despues de su instalación y ejecución
# con https://pagespeed.web.dev/
#

set -e

# --------------------------------------------------------------------
# Rutas
# --------------------------------------------------------------------

DOWNLOAD_URL="https://www.s-sols.com/data/products/wordpress/accelerator/Accelerator.zip"
ZIP_NAME="Accelerator.zip"
SRC_DIR="seraphinite-accelerator-ext"
DST_DIR="crealib-accelerator"
OUT_ZIP="crealib-accelerator.zip"

# --------------------------------------------------------------------
# Detección del idioma
# --------------------------------------------------------------------

LANG_CODE="${LANG%%_*}"
LANG_CODE="${LANG_CODE:-en}"

