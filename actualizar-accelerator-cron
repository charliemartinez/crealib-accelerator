#!/bin/bash

# ======================================================================
# Archivo:       actualizar-accelerator-cron
# Ruta:          /usr/local/bin/actualizar-accelerator-cron
# Autor:         Charlie Martinez <cmartinez@quirinux.org>
# Licencia:      https://www.gnu.org/licenses/gpl-2.0.txt
# Proposito:     Actualizacion automatica de crealib-accelerator
#                en todos los WordPress del servidor
# ======================================================================

# --------------------------------------------------------------------
# INSTALACION Y CONFIGURACION
# --------------------------------------------------------------------
#
# 1) Copiar este script al sistema y hacerlo ejecutable:
#
#       cp actualizar-accelerator-cron /usr/local/bin/
#       chmod +x /usr/local/bin/actualizar-accelerator-cron
#
# 2) Editar las variables de la seccion CONFIGURACION mas abajo,
#    especialmente EMAIL_DESTINO y las variables del bloque SMTP.
#
# --------------------------------------------------------------------
# CRON SEMANAL
# --------------------------------------------------------------------
#
# Para ejecutar automaticamente cada lunes a las 3:00 AM:
#
#       crontab -e
#
# Añadir la siguiente linea:
#
#       0 3 * * 1 /usr/local/bin/actualizar-accelerator-cron
#
# --------------------------------------------------------------------
# DEPENDENCIAS PARA ENVIO DE CORREO
# --------------------------------------------------------------------
#
# Este script usa msmtp como cliente SMTP. Para instalarlo:
#
#       apt-get install msmtp msmtp-mta mailutils -y
#
# El script puede gestionar automaticamente el archivo de configuracion
# /etc/msmtprc a partir de las variables SMTP_* definidas en la seccion
# CONFIGURACION de mas abajo.
#
# Si /etc/msmtprc no existe o sus valores difieren de los indicados en
# las variables, el script lo (re)creara antes de intentar el envio.
#
# Si prefieres gestionar /etc/msmtprc de forma manual, deja las
# variables SMTP_* vacias: el script usara el archivo existente sin
# modificarlo. En ese caso, el contenido esperado del archivo es:
#
#       defaults
#       auth           on
#       tls            on
#       tls_starttls   off       # off = SSL/TLS directo (puerto 465)
#       logfile        /var/log/msmtp.log
#
#       account        miservidor
#       host           smtp.midominio.com
#       port           465
#       from           envios@midominio.com
#       user           envios@midominio.com
#       password       mi_contrasena
#
#       account default : miservidor
#
# Asegurar permisos correctos tras editar a mano:
#
#       chmod 600 /etc/msmtprc
#
# Nota sobre puertos y cifrado:
#   - Puerto 465 + SSL/TLS directo  -> tls_starttls off  (recomendado)
#   - Puerto 587 + STARTTLS         -> tls_starttls on
#
# Para probar el envio manualmente:
#
#       echo "Prueba" | msmtp destinatario@ejemplo.com
#
# ======================================================================

# --------------------------------------------------------------------
# CONFIGURACION -- ajusta estos valores
# --------------------------------------------------------------------

EMAIL_DESTINO=""                       # Direccion destinataria del informe
EMAIL_ASUNTO="[Crealib Accelerator] Informe de actualizacion"
PLUGIN_SLUG="crealib-accelerator"
DOWNLOAD_URL="https://www.s-sols.com/data/products/wordpress/accelerator/Accelerator.zip"
ZIP_UPSTREAM="/tmp/Accelerator-upstream.zip"
ZIP_DESTINO="/tmp/crealib-accelerator.zip"
WORKDIR="/tmp/crealib-accelerator-work"
LOG=""

# --------------------------------------------------------------------
# CONFIGURACION SMTP -- deja en blanco para usar /etc/msmtprc existente
# --------------------------------------------------------------------
#
# Si estas variables tienen valor, el script comparara su contenido con
# /etc/msmtprc y lo actualizara automaticamente si hay diferencias.
# Si las dejas vacias, el archivo de configuracion no se tocara.

SMTP_HOST=""                            # Servidor SMTP
SMTP_PORT=""                            # 465 (SSL) o 587 (STARTTLS)
SMTP_FROM=""                            # Direccion remitente
SMTP_USER=""                            # Usuario SMTP
SMTP_PASS=""                            # Contrasena SMTP
SMTP_STARTTLS=""                        # "off" para SSL/TLS directo (465)
                                        # "on"  para STARTTLS (587)
SMTP_ACCOUNT=""                         # Nombre interno de la cuenta msmtp
SMTP_LOGFILE="/var/log/msmtp.log"       # Ruta del log de msmtp

# ======================================================================

# --------------------------------------------------------------------
# Gestion automatica de /etc/msmtprc
# --------------------------------------------------------------------

_configurar_msmtp() {

    local msmtprc="/etc/msmtprc"

    # Si no hay ninguna variable SMTP definida, no tocar nada
    if [ -z "$SMTP_HOST" ] && [ -z "$SMTP_PORT" ] && [ -z "$SMTP_FROM" ]  && \
       [ -z "$SMTP_USER" ] && [ -z "$SMTP_PASS" ] && [ -z "$SMTP_ACCOUNT" ] && \
       [ -z "$SMTP_STARTTLS" ] && [ -z "$SMTP_LOGFILE" ]; then
        return 0
    fi

    # Si el archivo no existe, necesitamos todas las variables para crearlo
    if [ ! -f "$msmtprc" ]; then
        if [ -z "$SMTP_HOST" ] || [ -z "$SMTP_PORT" ] || [ -z "$SMTP_FROM" ] || \
           [ -z "$SMTP_USER" ] || [ -z "$SMTP_PASS" ] || [ -z "$SMTP_ACCOUNT" ]; then
            _log "AVISO: /etc/msmtprc no existe y faltan variables SMTP_*. No se creara el archivo."
            _log "       Rellena todas las variables SMTP_* o crea /etc/msmtprc manualmente."
            return 1
        fi
        _log "$msmtprc no existe. Creando configuracion SMTP desde cero..."
        cat > "$msmtprc" <<EOF
defaults
auth           on
tls            on
tls_starttls   ${SMTP_STARTTLS:-off}
logfile        ${SMTP_LOGFILE:-/var/log/msmtp.log}

account        ${SMTP_ACCOUNT}
host           ${SMTP_HOST}
port           ${SMTP_PORT}
from           ${SMTP_FROM}
user           ${SMTP_USER}
password       ${SMTP_PASS}

account default : ${SMTP_ACCOUNT}
EOF
        chmod 600 "$msmtprc"
        _log "Archivo $msmtprc creado y permisos establecidos (600)."
        return 0
    fi

    # El archivo existe: copiar y sobreescribir solo los campos con variable definida
    local tmp="${msmtprc}.tmp.$$"
    cp "$msmtprc" "$tmp"

    # tls_starttls: linea unica en el bloque defaults
    [ -n "$SMTP_STARTTLS" ] && \
        sed -i "s/^\(tls_starttls[[:space:]]\+\).*/\1${SMTP_STARTTLS}/" "$tmp"

    # logfile: usa | como separador por si la ruta contiene /
    [ -n "$SMTP_LOGFILE" ] && \
        sed -i "s|^\(logfile[[:space:]]\+\).*|\1${SMTP_LOGFILE}|" "$tmp"

    # host, port, from, user, password: lineas unicas en el bloque account
    [ -n "$SMTP_HOST" ] && \
        sed -i "s/^\(host[[:space:]]\+\).*/\1${SMTP_HOST}/" "$tmp"
    [ -n "$SMTP_PORT" ] && \
        sed -i "s/^\(port[[:space:]]\+\).*/\1${SMTP_PORT}/" "$tmp"
    [ -n "$SMTP_FROM" ] && \
        sed -i "s/^\(from[[:space:]]\+\).*/\1${SMTP_FROM}/" "$tmp"
    [ -n "$SMTP_USER" ] && \
        sed -i "s/^\(user[[:space:]]\+\).*/\1${SMTP_USER}/" "$tmp"
    [ -n "$SMTP_PASS" ] && \
        sed -i "s/^\(password[[:space:]]\+\).*/\1${SMTP_PASS}/" "$tmp"

    # account aparece en dos lineas con formatos distintos, se tratan por separado:
    #   "account        nombre"      -> nombre de la cuenta
    #   "account default : nombre"   -> referencia al nombre de la cuenta
    if [ -n "$SMTP_ACCOUNT" ]; then
        sed -i "/^account default/! s/^\(account[[:space:]]\+\).*/\1${SMTP_ACCOUNT}/" "$tmp"
        sed -i "s/^\(account default : \).*/\1${SMTP_ACCOUNT}/" "$tmp"
    fi

    # Aplicar solo si hubo cambios reales
    if ! diff -q "$msmtprc" "$tmp" > /dev/null 2>&1; then
        mv "$tmp" "$msmtprc"
        chmod 600 "$msmtprc"
        _log "Archivo $msmtprc actualizado con los campos modificados."
    else
        rm -f "$tmp"
        _log "Configuracion SMTP sin cambios. No se modifico $msmtprc."
    fi
}

# --------------------------------------------------------------------
# Envio de email con control de errores
# --------------------------------------------------------------------

_enviar_email() {
    local asunto="$1"
    local destino="$2"
    local cuerpo="$3"

    # Comprobar que msmtp esta instalado
    if ! command -v msmtp &>/dev/null; then
        _log "AVISO: msmtp no esta instalado. No se enviara el informe por correo."
        _log "       Instalar con: apt-get install msmtp msmtp-mta mailutils -y"
        return 1
    fi

    # Intentar configurar/actualizar msmtprc si corresponde
    _configurar_msmtp

    # Comprobar que /etc/msmtprc existe y tiene contenido
    if [ ! -s /etc/msmtprc ]; then
        _log "AVISO: /etc/msmtprc no existe o esta vacio. No se enviara el informe."
        _log "       Revisa las variables SMTP_* en este script o crea /etc/msmtprc manualmente."
        return 1
    fi

    # Intentar el envio y capturar errores
    local error_output
    if error_output=$(printf "Subject: %s\nFrom: %s\nTo: %s\n\n%s" \
        "$asunto" "$SMTP_FROM" "$destino" "$cuerpo" \
        | msmtp "$destino" 2>&1); then
        _log "Informe enviado correctamente a $destino."
        return 0
    else
        _log "AVISO: Error al enviar el correo a $destino."
        _log "       Detalle: $error_output"
        _log "       El proceso de actualizacion finalizo con exito; solo fallo el envio."
        return 1
    fi
}

# --------------------------------------------------------------------
# Deteccion automatica de sitios WordPress
# --------------------------------------------------------------------

SITIOS=()
while IFS= read -r -d '' wp_config; do
    SITIOS+=("$(dirname "$wp_config")")
done < <(find /var/www -maxdepth 4 -name "wp-config.php" -print0 2>/dev/null)

# --------------------------------------------------------------------
# Funciones auxiliares
# --------------------------------------------------------------------

_log() {
    local msg="[$(date '+%Y-%m-%d %H:%M:%S')] $1"
    echo "$msg"
    LOG="${LOG}
${msg}"
}

_php_para_sitio() {
    local sitio="$1"
    local dominio
    dominio=$(basename "$(dirname "$sitio")")
    local version

    version=$(grep -rh "php.*fpm\|fastcgi_pass.*php\|php[0-9]\.[0-9]" \
        /etc/nginx/sites-enabled/ /etc/apache2/sites-enabled/ 2>/dev/null \
        | grep -i "$dominio" \
        | grep -oP 'php\K[0-9]+\.[0-9]+' \
        | head -1)

    if [ -n "$version" ] && command -v "php${version}" &>/dev/null; then
        echo "php${version} -d error_reporting=0"
        return
    fi

    version=$(find /etc/php -name "*.conf" 2>/dev/null \
        | xargs grep -l "$dominio" 2>/dev/null \
        | grep -oP '/etc/php/\K[0-9]+\.[0-9]+' \
        | head -1)

    if [ -n "$version" ] && command -v "php${version}" &>/dev/null; then
        echo "php${version} -d error_reporting=0"
        return
    fi

    echo "php8.2 -d error_reporting=0"
}

_version_instalada() {
    local sitio="$1"
    local php_cmd="$2"
    local resultado
    resultado=$($php_cmd /usr/local/bin/wp-cli.phar plugin get "$PLUGIN_SLUG" \
        --field=version --path="$sitio" --allow-root 2>/dev/null) || true
    echo "${resultado:-no-instalado}"
}

_version_upstream() {
    # Descarga el zip original y lee la version del plugin_root.php
    wget -qO "$ZIP_UPSTREAM" "$DOWNLOAD_URL" || true
    if [ ! -s "$ZIP_UPSTREAM" ]; then
        echo ""
        return
    fi
    unzip -p "$ZIP_UPSTREAM" "seraphinite-accelerator-ext/plugin_root.php" \
        | grep -oP "Version:\s*\K[\d.]+" | head -1
}

_version_mayor() {
    # Devuelve true si $1 > $2 usando sort -V
    [ "$(printf '%s\n' "$1" "$2" | sort -V | tail -1)" = "$1" ] && [ "$1" != "$2" ]
}

_generar_zip() {
    # El zip upstream ya fue descargado por _version_upstream, lo reutiliza
    _log "Generando zip parcheado con actualizar-accelerator..."
    rm -rf "$WORKDIR"
    mkdir -p "$WORKDIR"
    cp "$ZIP_UPSTREAM" "$WORKDIR/Accelerator.zip"
    cd "$WORKDIR"

    # Descomprimir y aplicar parche (replica lo que hace actualizar-accelerator)
    unzip -q Accelerator.zip
    SRC_DIR="seraphinite-accelerator-ext"
    DST_DIR="crealib-accelerator"

    if [ ! -d "$SRC_DIR" ]; then
        _log "ERROR: no se encontro la carpeta $SRC_DIR tras descomprimir."
        return 1
    fi

    # Parche content.php
    awk '
    /if\( \( \$ctxProcess\[ .mode. \] & 1 \) && \$seraph_accel_g_ahuddqrText \)/ {
        print "\tif( false ) /* Crealib: footer credits disabled */"
        next
    }
    { print }
    ' "$SRC_DIR/content.php" > "$SRC_DIR/content.php.tmp" && mv "$SRC_DIR/content.php.tmp" "$SRC_DIR/content.php"

    # Parche plugin_root.php
    awk '
    /Plugin Name:/ { print "Plugin Name: Crealib Accelerator"; next }
    /Plugin URI:/ { print "Plugin URI: https://www.crealib.net/plugin-accelerator"; next }
    /Author: Seraphinite/ { print "Author: Crealib Tecnologia Sostenible"; next }
    /Author URI:/ { print "Author URI: https://www.crealib.net"; next }
    { print }
    ' "$SRC_DIR/plugin_root.php" > "$SRC_DIR/plugin_root.php.tmp" && mv "$SRC_DIR/plugin_root.php.tmp" "$SRC_DIR/plugin_root.php"

    mv "$SRC_DIR" "$DST_DIR"
    zip -qr "$ZIP_DESTINO" "$DST_DIR"

    if [ ! -f "$ZIP_DESTINO" ]; then
        _log "ERROR: no se genero el zip final."
        return 1
    fi

    _log "Zip generado correctamente en $ZIP_DESTINO"
    return 0
}

# --------------------------------------------------------------------
# Proceso principal
# --------------------------------------------------------------------

_log "========== INICIO DE ACTUALIZACION CREALIB ACCELERATOR =========="
_log "Sitios detectados: ${#SITIOS[@]}"

# Obtener version upstream descargando el zip original
_log "Descargando zip upstream para verificar version..."
VERSION_UPSTREAM=$(_version_upstream)

if [ -z "$VERSION_UPSTREAM" ]; then
    _log "ERROR: no se pudo obtener la version upstream. Abortando."
    _enviar_email "$EMAIL_ASUNTO" "$EMAIL_DESTINO" "$LOG"
    exit 1
fi

_log "Version mas reciente de Seraphinite: $VERSION_UPSTREAM"

HUBO_CAMBIOS=false
ZIP_GENERADO=false

for SITIO in "${SITIOS[@]}"; do

    _log "--- Procesando: $SITIO"

    PHP_CMD=$(_php_para_sitio "$SITIO")
    _log "PHP detectado: $PHP_CMD"

    VERSION_ACTUAL=$(_version_instalada "$SITIO" "$PHP_CMD")

    if [ "$VERSION_ACTUAL" = "no-instalado" ]; then
        _log "El plugin no esta instalado en este sitio. Saltando."
        continue
    fi

    _log "Version instalada: $VERSION_ACTUAL"

    if ! _version_mayor "$VERSION_UPSTREAM" "$VERSION_ACTUAL"; then
        _log "El sitio ya esta al dia. Sin cambios."
        continue
    fi

    _log "Actualizacion disponible: $VERSION_ACTUAL -> $VERSION_UPSTREAM"
    HUBO_CAMBIOS=true

    # Generar zip parcheado solo una vez para todos los sitios
    if [ "$ZIP_GENERADO" = false ]; then
        if ! _generar_zip; then
            _log "ERROR CRITICO: No se pudo generar el zip. Abortando."
            break
        fi
        ZIP_GENERADO=true
    fi

    _log "Instalando crealib-accelerator en $SITIO..."
    if $PHP_CMD /usr/local/bin/wp-cli.phar plugin install "$ZIP_DESTINO" \
        --force --path="$SITIO" --allow-root > /dev/null 2>&1; then
        _log "OK Plugin actualizado en $SITIO (v$VERSION_UPSTREAM)"
    else
        _log "ERROR al instalar el plugin en $SITIO"
        HUBO_CAMBIOS=true
    fi

done

# --------------------------------------------------------------------
# Limpieza
# --------------------------------------------------------------------

rm -f "$ZIP_DESTINO" "$ZIP_UPSTREAM"
rm -rf "$WORKDIR"

_log "========== FIN DE ACTUALIZACION =========="

# --------------------------------------------------------------------
# Envio de email solo si hubo cambios o errores
# --------------------------------------------------------------------

if [ "$HUBO_CAMBIOS" = true ]; then
    _enviar_email "$EMAIL_ASUNTO" "$EMAIL_DESTINO" "$LOG"
fi
